<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="libopcode" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/opcode" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-ggdb3" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/opcode" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-std=c++20" />
			<Add option="-fexceptions" />
		</Compiler>
		<Unit filename="instr.l">
			<Option compile="1" />
			<Option compiler="gcc" use="1" buildCommand="flex -Pyyinstr -o$file_dir/$file_name.scanner.cpp $file" />
		</Unit>
		<Unit filename="instr.y">
			<Option compile="1" />
			<Option compiler="gcc" use="1" buildCommand="bison -v -pyyinstr -d $file -o $file_dir/$file_name.parser.cpp" />
		</Unit>
		<Unit filename="libopcode.cpp" />
		<Unit filename="libopcode.hpp" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
